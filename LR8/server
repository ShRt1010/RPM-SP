using System;
using System.IO;
using System.IO.Pipes;

// Создаю именованный канал с названием "lab8_pipe"
using var pipe = new NamedPipeServerStream("lab8_pipe", PipeDirection.InOut);

Console.WriteLine("Сервер запущен");
Console.WriteLine("Ожидание клиента...");

// Сервер ждёт подключения клиента
pipe.WaitForConnection();

Console.WriteLine("Клиент подключился");

// Reader нужен для чтения данных из канала
using var reader = new StreamReader(pipe);

// Читаю сообщение, которое отправил клиент
string? message = reader.ReadLine();

// Вывожу полученные данные
Console.WriteLine("Получены данные от клиента:");
Console.WriteLine(message);

Console.WriteLine("Сервер завершил работу");
