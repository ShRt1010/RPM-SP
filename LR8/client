using System;
using System.IO;
using System.IO.Pipes;

// Подключаюсь к именованному каналу "lab8_pipe"
using var pipe = new NamedPipeClientStream(".", "lab8_pipe", PipeDirection.Out);

Console.WriteLine("Клиент подключается к серверу...");

// Подключение к серверу
pipe.Connect();

Console.WriteLine("Клиент подключился");

// Writer нужен для отправки данных в канал
using var writer = new StreamWriter(pipe);

// Произвольные данные, которые отправляем серверу
string text = "Это произвольные данные для передачи через именованный канал";

// Отправляю текст в канал
writer.WriteLine(text);

// Очищаю буфер, чтобы данные точно отправились
writer.Flush();

Console.WriteLine("Данные отправлены серверу");
Console.WriteLine("Клиент завершил работу");
