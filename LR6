using ClosedXML.Excel;
using System.Threading;

// Файл Excel должен лежать рядом с программой
string file = "data.xlsx";

// Создаю два потока для чтения разных листов
Thread t1 = new Thread(() => ReadSheet(file, "Студенты", 2000));
Thread t2 = new Thread(() => ReadSheet(file, "Товары", 0));

// Даю потокам имена
t1.Name = "Поток 1";
t2.Name = "Поток 2";

// Статус до запуска
Console.WriteLine($"До запуска: {t1.Name} - {t1.ThreadState}");
Console.WriteLine($"До запуска: {t2.Name} - {t2.ThreadState}\n");

// Запускаю потоки
t1.Start();
t2.Start();

// Вывожу статус после запуска
Console.WriteLine($"После запуска: {t1.Name} - {t1.ThreadState}");
Console.WriteLine($"После запуска: {t2.Name} - {t2.ThreadState}\n");

// Жду завершения потоков
t1.Join();
t2.Join();

// Статус после завершения
Console.WriteLine($"\nПосле завершения: {t1.Name} - {t1.ThreadState}");
Console.WriteLine($"После завершения: {t2.Name} - {t2.ThreadState}");


// Метод для чтения листа Excel
static void ReadSheet(string file, string sheetName, int delay)
{
    // Задержка для одного потока
    Thread.Sleep(delay);

    Console.WriteLine($"Читается лист: {sheetName}");

    // Открываю Excel-файл
    using var book = new XLWorkbook(file);

    // Выбираю нужный лист
    var sheet = book.Worksheet(sheetName);

    // Вывожу данные из заполненных ячеек
    foreach (var row in sheet.RangeUsed().Rows())
    {
        foreach (var cell in row.Cells())
        {
            Console.Write(cell.Value + "\t");
        }

        Console.WriteLine();
    }

    Console.WriteLine();
}
