using ClosedXML.Excel;
using System.Threading;

// Имя Excel-файла
string fileName = "data.xlsx";

// Если файла нет, создаём его для проверки
if (!File.Exists(fileName))
{
    CreateExcelFile(fileName);
}

// Создаём первый поток для чтения листа "Студенты"
Thread thread1 = new Thread(() => ReadSheet(fileName, "Студенты", 2000));

// Создаём второй поток для чтения листа "Товары"
Thread thread2 = new Thread(() => ReadSheet(fileName, "Товары", 0));

// Даём потокам имена, чтобы было понятно в выводе
thread1.Name = "Поток 1";
thread2.Name = "Поток 2";

// Выводим статус до запуска
Console.WriteLine($"Статус {thread1.Name}: {thread1.ThreadState}");
Console.WriteLine($"Статус {thread2.Name}: {thread2.ThreadState}");
Console.WriteLine();

// Запускаем оба потока
thread1.Start();
thread2.Start();

// Выводим статус после запуска
Console.WriteLine($"Статус {thread1.Name}: {thread1.ThreadState}");
Console.WriteLine($"Статус {thread2.Name}: {thread2.ThreadState}");
Console.WriteLine();

// Ждём завершения потоков
thread1.Join();
thread2.Join();

// Выводим статус после завершения
Console.WriteLine();
Console.WriteLine($"Статус {thread1.Name}: {thread1.ThreadState}");
Console.WriteLine($"Статус {thread2.Name}: {thread2.ThreadState}");


// Метод создаёт Excel-файл с двумя листами
static void CreateExcelFile(string fileName)
{
    using var workbook = new XLWorkbook();

    // Первый лист
    var sheet1 = workbook.Worksheets.Add("Студенты");
    sheet1.Cell(1, 1).Value = "Имя";
    sheet1.Cell(1, 2).Value = "Возраст";
    sheet1.Cell(2, 1).Value = "Иван";
    sheet1.Cell(2, 2).Value = 18;
    sheet1.Cell(3, 1).Value = "Анна";
    sheet1.Cell(3, 2).Value = 19;

    // Второй лист
    var sheet2 = workbook.Worksheets.Add("Товары");
    sheet2.Cell(1, 1).Value = "Товар";
    sheet2.Cell(1, 2).Value = "Цена";
    sheet2.Cell(2, 1).Value = "Хлеб";
    sheet2.Cell(2, 2).Value = 45;
    sheet2.Cell(3, 1).Value = "Молоко";
    sheet2.Cell(3, 2).Value = 80;

    // Сохраняем файл
    workbook.SaveAs(fileName);
}


// Метод читает один лист Excel
static void ReadSheet(string fileName, string sheetName, int delay)
{
    // Задержка нужна по заданию для одного потока
    if (delay > 0)
    {
        Thread.Sleep(delay);
    }

    Console.WriteLine($"Читает {Thread.CurrentThread.Name}: лист {sheetName}");

    using var workbook = new XLWorkbook(fileName);

    // Открываем нужный лист
    var sheet = workbook.Worksheet(sheetName);

    // Берём область, где есть данные
    var range = sheet.RangeUsed();

    // Выводим все ячейки листа
    foreach (var row in range.Rows())
    {
        foreach (var cell in row.Cells())
        {
            Console.Write(cell.Value + "\t");
        }

        Console.WriteLine();
    }

    Console.WriteLine();
}
